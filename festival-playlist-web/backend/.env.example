FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
OPENAI_VISION_MODEL=gpt-4.1-mini

# Optional for YouTube search before OAuth login.
YOUTUBE_API_KEY=

# Required for YouTube OAuth playlist creation.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:8000/api/youtube/callback

# In-memory token/session TTL.
YOUTUBE_TOKEN_TTL_SECONDS=3600
YOUTUBE_STATE_TTL_SECONDS=600
